# Nagarkot OS Frontend environment example
#
# This Next.js app uses:
# - OS_BACKEND_URL for server-side /api rewrites
# - NEXT_PUBLIC_OS_BACKEND_URL for browser-side direct retry fallback
#
# Keep only one value per variable in your real .env.

# -----------------------------------------------------------------------------
# Development
# -----------------------------------------------------------------------------

# Backend root used by next.config.ts rewrites.
OS_BACKEND_URL=http://localhost:3001

# Browser fallback target used by src/lib/api.ts.
NEXT_PUBLIC_OS_BACKEND_URL=http://localhost:3001

# -----------------------------------------------------------------------------
# Production example
# -----------------------------------------------------------------------------

# If the frontend can reach the backend on an internal network, prefer that here:
# OS_BACKEND_URL=http://os-project-backend:3001
#
# If you must go through the public ingress instead:
# OS_BACKEND_URL=https://os.int.nagarkot.co.in/api
#
# Browser fallback must always be a public URL reachable from the browser.
# If your public API lives under /api, include /api here.
# NEXT_PUBLIC_OS_BACKEND_URL=https://os.int.nagarkot.co.in/api

# -----------------------------------------------------------------------------
# Notes
# -----------------------------------------------------------------------------

# NEXT_PUBLIC_INTERNAL_BACKEND_URL is not used by the current codebase.
# After changing NEXT_PUBLIC_* values, rebuild the frontend.
