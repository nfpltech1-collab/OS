# Nagarkot OS Backend environment example
#
# This file shows both development and production-style values.
# Keep only one value per variable in your real .env.

# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------

# Development:
NODE_ENV=development
PORT=3001
HOST=0.0.0.0
PUBLIC_BASE_URL=http://localhost:3001
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174,http://localhost:8000
OS_FRONTEND_URL=http://localhost:3000

# Production example:
# NODE_ENV=production
# PORT=3001
# HOST=0.0.0.0
# PUBLIC_BASE_URL=https://os.int.nagarkot.co.in
# CORS_ORIGINS=https://os.int.nagarkot.co.in,https://trainings.int.nagarkot.co.in
# OS_FRONTEND_URL=https://os.int.nagarkot.co.in

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------

# Development:
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=postgres
DB_NAME=nagarkot-os

# Production example:
# DB_HOST=<postgres-host>
# DB_PORT=5432
# DB_USER=<postgres-user>
# DB_PASS=<postgres-password>
# DB_NAME=nagarkot-os

# -----------------------------------------------------------------------------
# Session cookie (HS256)
# -----------------------------------------------------------------------------

OS_SESSION_SECRET=replace-with-a-long-random-session-secret
OS_SESSION_EXPIRES_IN=8h

# -----------------------------------------------------------------------------
# Internal auth + webhook signing
# -----------------------------------------------------------------------------

INTERNAL_API_KEY=replace-with-shared-internal-api-key
WEBHOOK_SECRET=replace-with-webhook-hmac-secret

# -----------------------------------------------------------------------------
# RS256 keypair for SSO
# -----------------------------------------------------------------------------

OS_JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n<private-key>\n-----END RSA PRIVATE KEY-----"
OS_JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n<public-key>\n-----END PUBLIC KEY-----"

# -----------------------------------------------------------------------------
# Optional seeded admin
# -----------------------------------------------------------------------------

SEED_ADMIN_EMAIL=admin@nagarkot.com
SEED_ADMIN_PASSWORD=Admin@1234
SEED_ADMIN_NAME=Admin

# -----------------------------------------------------------------------------
# Optional seeded app URLs
# These are useful for fresh environments and local seed data.
# -----------------------------------------------------------------------------

# Development:
APP_SUPERFREIGHT_URL=http://localhost:3002
APP_SUPERFREIGHT_WEBHOOK_URL=http://localhost:3002/webhooks/os
APP_SUPERFREIGHT_ACTIVE=true

APP_TEZ_URL=http://localhost:3003
APP_TEZ_WEBHOOK_URL=http://localhost:3003/webhooks/os
APP_TEZ_ACTIVE=true

APP_TRAININGS_URL=http://localhost:5173
APP_TRAININGS_WEBHOOK_URL=http://localhost:8000/webhooks/os
APP_TRAININGS_ACTIVE=true

APP_SHAKTI_URL=http://localhost:3004
APP_SHAKTI_WEBHOOK_URL=http://localhost:3004/webhooks/os
APP_SHAKTI_ACTIVE=false

# Production example:
# APP_SUPERFREIGHT_URL=https://superfreight.int.nagarkot.co.in
# APP_SUPERFREIGHT_WEBHOOK_URL=https://superfreight.int.nagarkot.co.in/webhooks/os
# APP_SUPERFREIGHT_ACTIVE=true
#
# APP_TEZ_URL=https://tez.int.nagarkot.co.in
# APP_TEZ_WEBHOOK_URL=https://tez.int.nagarkot.co.in/webhooks/os
# APP_TEZ_ACTIVE=true
#
# APP_TRAININGS_URL=https://trainings.int.nagarkot.co.in
# APP_TRAININGS_WEBHOOK_URL=https://trainings.int.nagarkot.co.in/webhooks/os
# APP_TRAININGS_ACTIVE=true
#
# APP_SHAKTI_URL=https://shakti.int.nagarkot.co.in
# APP_SHAKTI_WEBHOOK_URL=https://shakti.int.nagarkot.co.in/webhooks/os
# APP_SHAKTI_ACTIVE=false

# -----------------------------------------------------------------------------
# Optional sync script overrides
# -----------------------------------------------------------------------------

SYNC_TRAININGS_URL=http://localhost:5173
SYNC_OS_DASHBOARD_URL=http://localhost:3000

# Production example:
# SYNC_TRAININGS_URL=https://trainings.int.nagarkot.co.in
# SYNC_OS_DASHBOARD_URL=https://os.int.nagarkot.co.in
