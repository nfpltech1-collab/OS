# Runtime
NODE_ENV=development
PORT=3001
HOST=0.0.0.0
PUBLIC_BASE_URL=http://localhost:3001
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=postgres
DB_NAME=nagarkot-os

# Session cookie (HS256)
OS_SESSION_SECRET=change-me-session-secret
OS_SESSION_EXPIRES_IN=8h

# Internal auth + webhook signing
INTERNAL_API_KEY=change-me-internal-key
WEBHOOK_SECRET=change-me-webhook-secret

# RS256 keypair used for SSO tokens
OS_JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
OS_JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# Optional seed admin credentials
SEED_ADMIN_EMAIL=admin@nagarkot.com
SEED_ADMIN_PASSWORD=Admin@1234
SEED_ADMIN_NAME=Admin

# Optional seeded app URLs (override defaults if needed)
APP_SUPERFREIGHT_URL=http://localhost:3002
APP_SUPERFREIGHT_WEBHOOK_URL=http://localhost:3002/webhooks/os
APP_SUPERFREIGHT_ACTIVE=true

APP_TEZ_URL=http://localhost:3003
APP_TEZ_WEBHOOK_URL=http://localhost:3003/webhooks/os
APP_TEZ_ACTIVE=true

APP_TRAININGS_URL=http://localhost:5173
APP_TRAININGS_WEBHOOK_URL=http://localhost:8000/webhooks/os
APP_TRAININGS_ACTIVE=true

APP_SHAKTI_URL=http://localhost:3004
APP_SHAKTI_WEBHOOK_URL=http://localhost:3004/webhooks/os
APP_SHAKTI_ACTIVE=false

# Optional URL sync script overrides
SYNC_TRAININGS_URL=http://localhost:5173
SYNC_OS_DASHBOARD_URL=http://localhost:3000
OS_FRONTEND_URL=http://localhost:3000
